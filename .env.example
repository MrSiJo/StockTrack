# ─── App bootstrap ───────────────────────────────────────────────────────────
APP_SECRET_KEY=change-me-to-a-32+-char-random-string
DATABASE_URL=sqlite+aiosqlite:////data/stocktrack.db
DATA_DIR=/data
BACKEND_PORT=9180
FRONTEND_PORT=9181
TZ=Europe/London
LOG_LEVEL=INFO

# ─── Gotify push notifications ───────────────────────────────────────────────
# Set GOTIFY_URL and GOTIFY_TOKEN in the host .env (never commit real values).
GOTIFY_URL=
GOTIFY_TOKEN=
GOTIFY_PRIORITY=7
RESTOCK_PRIORITY=8
NEW_PRODUCT_PRIORITY=8
OOS_PRIORITY=4
PRICE_DROP_PRIORITY=6
LEAD_TIME_PRIORITY=5
GOTIFY_SEND_RETRIES=3
ALERT_GROUP_THRESHOLD=3

# ─── Poller defaults ─────────────────────────────────────────────────────────
FAILURE_ALERT_AFTER=6
EVENT_RETENTION_DAYS=0
DEFAULT_INTERVAL_SECONDS=300
EARLY_ACCESS_DAYS=30

# ─── Site / price-drop behaviour ─────────────────────────────────────────────
AO_MEMBER=false
PRICE_DROP_MIN_PCT=5
PRICE_DROP_MIN_ABS=5
PRICE_DROP_IN_STOCK_ONLY=true
LEAD_TIME_MIN_CHANGE_DAYS=7
CP_DELIVERY_POSTCODE=
CP_COLLECTION_BRANCH_ID=

# ─── Digest (off | daily | weekly) ───────────────────────────────────────────
DIGEST_CADENCE=off
DIGEST_HOUR=8
DIGEST_PRIORITY=4

# ─── Seed watches (optional) ─────────────────────────────────────────────────
# optional: auto-seed a watch for this store on first boot; leave blank to add watches via the UI
SEED_AO_URL=
SEED_JL_URL=
